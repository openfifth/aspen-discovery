<?xml version="1.0" ?>
<!--
TODO:
- Version 25.10 introduced docValues for several fields. To preserve search capability while reindexing records,
  the indexed attribute was left at true. This can be set to false in 25.11 or later to clear index space.
-->
<schema name="Aspen Grouped Work Index" version="1.5">
	<types>
		<fieldType name="unchanged_string" class="StrField"/>
		<fieldType name="integer" class="IntPointField"/>
		<fieldType name="long" class="LongPointField"/>
		<fieldType name="float" class="FloatPointField"/>
		<fieldType name="date" class="DatePointField"/>
		<fieldType name="random" class="RandomSortField"/>
		<fieldType name="text_general" class="solr.TextField" positionIncrementGap="100">
			<analyzer type="index">
				<tokenizer class="solr.StandardTokenizerFactory"/>
				<charFilter class="solr.PatternReplaceCharFilterFactory" pattern="(\&amp;)" replacement="and"/>
				<filter class="solr.ICUFoldingFilterFactory" />
				<filter class="solr.StopFilterFactory" ignoreCase="true" words="stopwords.txt"  />
				<filter class="solr.LowerCaseFilterFactory"/>
			</analyzer>
			<analyzer type="query">
				<tokenizer class="solr.StandardTokenizerFactory"/>
				<charFilter class="solr.PatternReplaceCharFilterFactory" pattern="(\&amp;)" replacement="and"/>
				<filter class="solr.ICUFoldingFilterFactory" />
				<filter class="solr.StopFilterFactory" ignoreCase="true" words="stopwords.txt"  />
				<filter class="solr.SynonymGraphFilterFactory" synonyms="synonyms.txt" ignoreCase="true" expand="true"/>
				<filter class="solr.LowerCaseFilterFactory"/>
			</analyzer>
		</fieldType>
		<fieldType name="searchable_text" class="solr.TextField" positionIncrementGap="100">
			<analyzer type="index">
				<!-- Whitespace tokenizer is needed so the Word Delimiter filter factory works properly
				 For example, this allows E.T. The Extra-Terrestrial to be handled properly.  #ARL-168
				-->
				<tokenizer class="solr.StandardTokenizerFactory"/>
				<charFilter class="solr.PatternReplaceCharFilterFactory" pattern="(\&amp;)" replacement="and"/>
				<filter class="solr.ICUFoldingFilterFactory"/>
				<filter class="solr.WordDelimiterGraphFilterFactory" generateWordParts="1" generateNumberParts="1" catenateWords="1" catenateNumbers="1" catenateAll="0" splitOnCaseChange="1" preserveOriginal="1"/>
				<!-- We have not defined words so this is not needed <filter class="solr.CommonGramsFilterFactory" words="stopwords.txt" ignoreCase="true"/> -->
				<!-- We have not defined words so this is not needed <filter class="solr.KeywordMarkerFilterFactory" protected="protwords.txt"/> -->
				<filter class="solr.KeywordRepeatFilterFactory" />
				<filter class="solr.SnowballPorterFilterFactory" language="English"/>
				<filter class="solr.LowerCaseFilterFactory"/>
				<filter class="solr.RemoveDuplicatesTokenFilterFactory"/>
			</analyzer>
			<analyzer type="query">
				<!-- Whitespace tokenizer is needed so the Word Delimiter filter factory works properly
				 For example, this allows E.T. The Extra-Terrestrial to be handled properly.  #ARL-168
				-->
				<tokenizer class="solr.StandardTokenizerFactory"/>
				<charFilter class="solr.PatternReplaceCharFilterFactory" pattern="(\&amp;)" replacement="and"/>
				<filter class="solr.ICUFoldingFilterFactory"/>
				<filter class="solr.SynonymGraphFilterFactory" synonyms="synonyms.txt" ignoreCase="true" expand="true"/>
				<filter class="solr.WordDelimiterGraphFilterFactory" generateWordParts="1" generateNumberParts="1" catenateWords="1" catenateNumbers="1" catenateAll="0" splitOnCaseChange="1" preserveOriginal="1"/>
				<!-- We have not defined words, so this is not needed <filter class="solr.CommonGramsFilterFactory" words="stopwords.txt" ignoreCase="true"/> -->
				<!-- We have not defined words, so this is not needed <filter class="solr.KeywordMarkerFilterFactory" protected="protwords.txt"/> -->
				<!-- Need to stem the search in case the patron doesn't enter stemming in the same order -->
				<filter class="solr.SnowballPorterFilterFactory" language="English"/>
				<filter class="solr.LowerCaseFilterFactory"/>
				<filter class="solr.RemoveDuplicatesTokenFilterFactory"/>
			</analyzer>
		</fieldType>
		<fieldType name="searchable_text_minimal_stem" class="solr.TextField" positionIncrementGap="100">
			<analyzer type="index">
				<!-- Whitespace tokenizer is needed so the Word Delimiter filter factory works properly.
				 For example, this allows E.T. The Extra-Terrestrial to be handled properly.  #ARL-168
				-->
				<tokenizer class="solr.StandardTokenizerFactory"/>
				<charFilter class="solr.PatternReplaceCharFilterFactory" pattern="(\&amp;)" replacement="and"/>
				<filter class="solr.ICUFoldingFilterFactory"/>
				<filter class="solr.WordDelimiterGraphFilterFactory" generateWordParts="1" generateNumberParts="1" catenateWords="1" catenateNumbers="1" catenateAll="0" splitOnCaseChange="1" preserveOriginal="1"/>
				<filter class="solr.KeywordRepeatFilterFactory" />
				<filter class="solr.KStemFilterFactory"/>
				<filter class="solr.LowerCaseFilterFactory"/>
				<filter class="solr.RemoveDuplicatesTokenFilterFactory"/>
			</analyzer>
			<analyzer type="query">
				<!-- Whitespace tokenizer is needed so the Word Delimiter filter factory works properly.
				 For example, this allows E.T. The Extra-Terrestrial to be handled properly.  #ARL-168
				-->
				<tokenizer class="solr.StandardTokenizerFactory"/>
				<charFilter class="solr.PatternReplaceCharFilterFactory" pattern="(\&amp;)" replacement="and"/>
				<filter class="solr.ICUFoldingFilterFactory"/>
				<filter class="solr.SynonymGraphFilterFactory" synonyms="synonyms.txt" ignoreCase="true" expand="true"/>
				<filter class="solr.WordDelimiterGraphFilterFactory" generateWordParts="1" generateNumberParts="1" catenateWords="1" catenateNumbers="1" catenateAll="0" splitOnCaseChange="1" preserveOriginal="1"/>
				<filter class="solr.KeywordRepeatFilterFactory" />
				<filter class="solr.KStemFilterFactory"/>
				<filter class="solr.LowerCaseFilterFactory"/>
				<filter class="solr.RemoveDuplicatesTokenFilterFactory"/>
			</analyzer>
		</fieldType>
		<fieldType name="searchable_text_unstemmed" class="solr.TextField" positionIncrementGap="100">
			<analyzer type="index">
				<!-- Whitespace tokenizer is needed so the Word Delimiter filter factory works properly.
				 For example, this allows E.T. The Extra-Terrestrial to be handled properly.  #ARL-168
				-->
				<tokenizer class="solr.StandardTokenizerFactory"/>
				<charFilter class="solr.PatternReplaceCharFilterFactory" pattern="(\&amp;)" replacement="and"/>
				<filter class="solr.ICUFoldingFilterFactory"/>
				<filter class="solr.WordDelimiterGraphFilterFactory" generateWordParts="1" generateNumberParts="1" catenateWords="1" catenateNumbers="1" catenateAll="0" splitOnCaseChange="1" preserveOriginal="1"/>
				<filter class="solr.KeywordRepeatFilterFactory" />
				<filter class="solr.LowerCaseFilterFactory"/>
				<filter class="solr.RemoveDuplicatesTokenFilterFactory"/>
			</analyzer>
			<analyzer type="query">
				<!-- Whitespace tokenizer is needed so the Word Delimiter filter factory works properly.
				 For example, this allows E.T. The Extra-Terrestrial to be handled properly.  #ARL-168
				-->
				<tokenizer class="solr.StandardTokenizerFactory"/>
				<charFilter class="solr.PatternReplaceCharFilterFactory" pattern="(\&amp;)" replacement="and"/>
				<filter class="solr.ICUFoldingFilterFactory"/>
				<filter class="solr.SynonymGraphFilterFactory" synonyms="synonyms.txt" ignoreCase="true" expand="true"/>
				<filter class="solr.WordDelimiterGraphFilterFactory" generateWordParts="1" generateNumberParts="1" catenateWords="1" catenateNumbers="1" catenateAll="0" splitOnCaseChange="1" preserveOriginal="1"/>
				<filter class="solr.LowerCaseFilterFactory"/>
				<filter class="solr.RemoveDuplicatesTokenFilterFactory"/>
			</analyzer>
		</fieldType>
		<fieldType name="text-exact" class="solr.TextField" sortMissingLast="true" omitNorms="true">
			<analyzer>
				<!-- Whitespace tokenizer is needed so the Word Delimiter filter factory works properly.
				 For example, this allows E.T. The Extra-Terrestrial to be handled properly.  #ARL-168
				-->
				<tokenizer class="solr.KeywordTokenizerFactory"/>
				<charFilter class="solr.PatternReplaceCharFilterFactory" pattern="(\&amp;)" replacement="and"/>
				<charFilter class="solr.PatternReplaceCharFilterFactory" pattern="^\s*(.*)\s*$" replacement="aaaa $1 zzzz"/>
				<filter class="solr.LowerCaseFilterFactory"/>
				<filter class="solr.RemoveDuplicatesTokenFilterFactory"/>
			</analyzer>
		</fieldType>
		<fieldType name="text-left" class="solr.TextField" sortMissingLast="true" omitNorms="true">
			<analyzer type="index">
				<tokenizer class="solr.KeywordTokenizerFactory"/>
				<charFilter class="solr.PatternReplaceCharFilterFactory" pattern="(\&amp;)" replacement="and"/>
				<charFilter class="solr.PatternReplaceCharFilterFactory" pattern="^\s*(.*)\s*$" replacement="aaaa $1"/>
				<filter class="solr.LowerCaseFilterFactory"/>
				<filter class="solr.EdgeNGramFilterFactory" minGramSize="5" maxGramSize="50"/>
				<filter class="solr.RemoveDuplicatesTokenFilterFactory"/>
			</analyzer>
			<analyzer type="query">
				<tokenizer class="solr.KeywordTokenizerFactory"/>
				<charFilter class="solr.PatternReplaceCharFilterFactory" pattern="(\&amp;)" replacement="and"/>
				<charFilter class="solr.PatternReplaceCharFilterFactory" pattern="^\s*(.*)\s*$" replacement="aaaa $1"/>
				<filter class="solr.LowerCaseFilterFactory"/>
				<filter class="solr.TrimFilterFactory"/>
			</analyzer>
		</fieldType>
		<!-- Text Field without Stemming, Synonyms, and stop Word removal -->
		<fieldType name="textProper" class="solr.TextField" positionIncrementGap="100">
			<analyzer>
				<tokenizer class="solr.WhitespaceTokenizerFactory"/>
				<charFilter class="solr.PatternReplaceCharFilterFactory" pattern="(\&amp;)" replacement="and"/>
				<filter class="solr.WordDelimiterGraphFilterFactory" generateWordParts="1" generateNumberParts="1" catenateWords="1" catenateNumbers="1" catenateAll="0" splitOnCaseChange="1" preserveOriginal="1"/>
				<filter class="solr.LowerCaseFilterFactory"/>
				<filter class="solr.RemoveDuplicatesTokenFilterFactory"/>
			</analyzer>
		</fieldType>
		<fieldType name="textSpelling" class="solr.TextField">
			<analyzer>
				<tokenizer class="solr.WhitespaceTokenizerFactory"/>
				<filter class="solr.LowerCaseFilterFactory"/>
				<filter class="solr.WordDelimiterGraphFilterFactory" generateWordParts="1" generateNumberParts="1" catenateWords="1" catenateNumbers="1" catenateAll="0" splitOnCaseChange="1" preserveOriginal="0"/>
				<filter class="solr.RemoveDuplicatesTokenFilterFactory"/>
			</analyzer>
		</fieldType>
		<fieldType name="textSuggest" class="solr.TextField" positionIncrementGap="100">
			<analyzer>
				<tokenizer class="solr.StandardTokenizerFactory"/>
				<filter class="solr.LowerCaseFilterFactory"/>
				<filter class="solr.TrimFilterFactory"/>
			</analyzer>
		</fieldType>
		<fieldType name="callnumber-search" class="solr.TextField">
			<analyzer>
				<tokenizer class="solr.WhitespaceTokenizerFactory"/>
				<filter class="solr.WordDelimiterGraphFilterFactory" generateWordParts="1" generateNumberParts="0" catenateWords="0" catenateNumbers="1" catenateAll="0" splitOnCaseChange="0" splitOnNumerics="1" preserveOriginal="1"/>
				<filter class="solr.LengthFilterFactory" min="2" max="100"/>
				<filter class="solr.LowerCaseFilterFactory"/>
				<filter class="solr.TrimFilterFactory"/>
			</analyzer>
		</fieldType>
		<!-- Text Field without Stemming, Synonyms, and stop Word removal -->
		<fieldType name="alphaOnlySort" class="solr.TextField" sortMissingLast="true">
			<analyzer>
				<tokenizer class="solr.KeywordTokenizerFactory"/>
				<filter class="solr.LowerCaseFilterFactory"/>
				<!-- The TrimFilter removes any leading or trailing whitespace -->
				<filter class="solr.TrimFilterFactory"/>
				<filter class="solr.PatternReplaceFilterFactory" pattern="([^a-z1-9\s])" replacement="" replace="all"/>
			</analyzer>
		</fieldType>
	</types>

	<fields>
		<!-- This is returned -->
		<field name="id" type="unchanged_string" indexed="true" stored="true" multiValued="false" required="true" omitNorms="true" omitTermFreqAndPositions="true"/>
		<!-- This is returned -->
		<field name="recordtype" type="unchanged_string" indexed="true" stored="true" multiValued="false" required="true" omitNorms="true" omitTermFreqAndPositions="true"/>
		<field name="_version_" type="long" indexed="true" stored="true"/>

		<!-- Used for diagnostic information in staff view -->
		<!-- This is returned -->
		<field name="last_indexed" type="date" indexed="false" stored="true"/>

		<!-- IDs of records that make up the work -->
		<field name="alternate_ids" type="unchanged_string" indexed="true" stored="false" multiValued="true" omitNorms="true" omitTermFreqAndPositions="true"/>

		<!-- TITLE information -->
		<!-- indexed title with subtitle -->
		<field name="title" type="searchable_text" indexed="true" stored="false"/>
		<!-- Title for display not including the subtitle -->
		<!-- This is returned -->
		<field name="title_display" type="unchanged_string" indexed="false" stored="true"/>
		<!-- This is returned -->
		<field name="subtitle_display" type="unchanged_string" indexed="false" stored="true"/>
		<!-- title for sorting only -->
		<field name="title_sort" type="alphaOnlySort" indexed="true" stored="false" omitNorms="true" omitTermFreqAndPositions="true"/>
		<!-- variations of title for searching -->
		<field name="title_exact" type="text-exact" indexed="true" stored="false"/>
		<field name="title_left" type="text-left" indexed="true" stored="false" multiValued="true"/>
		<field name="title_proper" type="textProper" indexed="true" stored="false"/>
		<!-- Title full includes the author -->
		<!-- This is returned -->
		<field name="title_full" type="searchable_text" indexed="true" stored="true" multiValued="true"/>
		<!-- This is returned, but not index. Can likely remove -->
		<field name="title_short" type="searchable_text" indexed="false" stored="true"/>
		<field name="title_alt" type="searchable_text" indexed="true" stored="false" multiValued="true"/>
		<!-- This does not seem to be used, can likely remove -->
		<field name="title_old" type="searchable_text" indexed="false" stored="false" multiValued="true"/>
		<field name="title_new" type="searchable_text" indexed="true" stored="false" multiValued="true"/>

		<!-- AUTHOR INFORMATION -->
		<!-- This is returned -->
		<field name="author" type="searchable_text_unstemmed" indexed="true" stored="false" />
		<!-- This is returned -->
		<!-- The author to display to the user -->
		<field name="author_display" type="unchanged_string" indexed="false" stored="true" multiValued="false"/>
		<!-- This is used for facet values and in the mlt handler. There are too many unique values for docValues to be useful -->
		<field name="authorStr" type="unchanged_string" indexed="true" stored="false" termVectors="true"/>
		<field name="author_exact" type="text-exact" indexed="true" stored="false" />
		<field name="author_left" type="text-left" indexed="true" stored="false" />
		<field name="auth_author" type="textProper" indexed="true" stored="false"/>
		<field name="author2" type="searchable_text_unstemmed" indexed="true" stored="false" multiValued="true"/>
		<!-- This is returned for Talpa only -->
		<field name="author2Str" type="unchanged_string" indexed="false" stored="true" multiValued="true"/>
		<!-- This is returned but not searched -->
		<field name="author2-role" type="unchanged_string" indexed="false" stored="true" multiValued="true"/> <!-- The contributor with role and title appended -->
		<!-- This is returned -->
		<field name="auth_author2" type="textProper" indexed="true" stored="true" multiValued="true"/>
		<field name="author_additional" type="searchable_text" indexed="true" stored="false" multiValued="true"/>

		<!-- TITLE/AUTHOR -->
		<field name="title_author" type="searchable_text" indexed="true" stored="false" multiValued="true"/>

		<!-- SERIES Fields -->
		<!-- This is returned -->
		<field name="series" type="searchable_text" indexed="true" stored="true" multiValued="true"/>
		<!-- This is used as a facet. There are too many values for docValues to be useful. -->
		<field name="series_facet" type="unchanged_string" indexed="true" stored="false" multiValued="true" omitNorms="true" omitTermFreqAndPositions="true"/>
		<field name="series_proper" type="textProper" indexed="true" stored="false" multiValued="true"/>
		<!-- This is returned -->
		<field name="series_with_volume" type="textProper" indexed="false" stored="true" multiValued="true"/>

		<field name="series_author" type="searchable_text" indexed="true" stored="false" multiValued="true"/>

		<!-- Information about related records, this is now stored in the database for faster access and smaller solr index -->
		<!-- These are all deprecated and no longer used unless Store Record Details In Solr is on in System Variables  -->
		<field name="record_details" type="unchanged_string" indexed="false" stored="true" multiValued="true"/>
		<field name="item_details" type="unchanged_string" indexed="false" stored="true" multiValued="true"/>
		<!-- This is returned but no longer seems needed -->
		<dynamicField name="scoping_details_*" type="unchanged_string" indexed="false" stored="true" multiValued="true"/>

		<!-- The popularity of a title in terms of circulation activity -->
		<!-- This is used for sorting and boost function - todo set indexed to false -->
		<field name="popularity" type="integer" indexed="true" stored="false" default="0" docValues="true" omitNorms="true" omitTermFreqAndPositions="true"/>
		<!-- This is used for sorting and boost function - todo set indexed to false -->
		<field name="total_holds" type="integer" indexed="true" stored="false" default="0" docValues="true" omitNorms="true" omitTermFreqAndPositions="true"/>

		<!-- Format information - todo set indexed to false -->
		<field name="grouping_category" type="unchanged_string" indexed="true" stored="false" multiValued="false" docValues="true" omitNorms="true" omitTermFreqAndPositions="true"/>
		<!-- This is returned and used as a facet -->
		<field name="format" type="unchanged_string" indexed="true" stored="true" multiValued="true" docValues="true" omitNorms="true" omitTermFreqAndPositions="true"/>
		<!-- Used for boosting functions - todo set indexed to false -->
		<field name="format_boost" type="integer" indexed="true" stored="false" docValues="true" omitNorms="true" omitTermFreqAndPositions="true"/>
		<!-- This is returned and used as a facet -->
		<field name="format_category" type="unchanged_string" indexed="true" stored="true" multiValued="true" docValues="true" omitNorms="true" omitTermFreqAndPositions="true"/>

		<!-- Fields to determine ownership and location based on location codes -->
		<!-- This is returned and used as a facet -->
		<field name="owning_library" type="unchanged_string" indexed="true" stored="true" multiValued="true" docValues="true" omitNorms="true" omitTermFreqAndPositions="true"/>
		<!-- This is returned and used as a facet -->
		<field name="owning_location" type="unchanged_string" indexed="true" stored="true" multiValued="true" docValues="true" omitNorms="true" omitTermFreqAndPositions="true"/>
		<!-- This is returned and used as a facet -->
		<field name="collection" type="unchanged_string" indexed="true" stored="true" multiValued="true" docValues="true" omitNorms="true" omitTermFreqAndPositions="true"/>
		<!-- This is returned and used as a facet -->
		<field name="detailed_location" type="unchanged_string" indexed="true" stored="true" multiValued="true" docValues="true" omitNorms="true" omitTermFreqAndPositions="true"/>
		<!-- This is returned and used as a facet -->
		<field name="shelf_location" type="unchanged_string" indexed="true" stored="true" multiValued="true" docValues="true" omitNorms="true" omitTermFreqAndPositions="true"/>

		<!-- Fields to determine availability -->
		<!-- This is returned and used as a facet -->
		<field name="available_at" type="unchanged_string" indexed="true" stored="true" multiValued="true" docValues="true" omitNorms="true" omitTermFreqAndPositions="true"/>
		<!-- This is returned and used as a facet -->
		<field name="availability_toggle" type="unchanged_string" indexed="true" stored="true" multiValued="true" docValues="true" omitNorms="true" omitTermFreqAndPositions="true"/>

		<!-- Language Related Fields -->
		<!-- This is returned and used as a facet and in mlt handler -->
		<field name="language" type="unchanged_string" indexed="true" stored="true" multiValued="true" omitNorms="true" docValues="true" termVectors="true"/>
		<!-- This is used as a facet -->
		<field name="translation" type="unchanged_string" indexed="true" stored="true" multiValued="true" omitNorms="true" docValues="true" omitTermFreqAndPositions="true"/>
		<!-- This is used for boost functions -->
		<field name="language_boost" type="integer" indexed="false" stored="false" multiValued="false" omitNorms="true" default="1" omitTermFreqAndPositions="true"/>
		<field name="language_boost_es" type="integer" indexed="false" stored="false" multiValued="false" omitNorms="true" default="1" omitTermFreqAndPositions="true"/>

		<!-- Publication information -->
		<!-- This is used for searching by publisher only -->
		<field name="publisher" type="searchable_text_minimal_stem" indexed="true" stored="true" multiValued="true"/>
		<!-- This is returned and used as a facet. There are too many valued for docValues to be useful -->
		<field name="publisherStr" type="unchanged_string" indexed="true" stored="true" multiValued="true" omitNorms="true" omitTermFreqAndPositions="true"/>
		<!-- This is returned, can be used for searching, and is used for facets -->
		<field name="publishDate" type="unchanged_string" indexed="true" stored="true" multiValued="true" docValues="true"/>
		<!-- This is returned and used as a facet. It is the earliest publication date -->
		<field name="publishDateSort" type="unchanged_string" indexed="true" stored="true" omitNorms="true" omitTermFreqAndPositions="true"/>
		<!-- This is returned and used as a facet. -->
		<field name="placeOfPublication" type="unchanged_string" indexed="true" stored="true" multiValued="true" docValues="true" omitNorms="true" omitTermFreqAndPositions="true"/>

		<!-- Facets -->
		<!-- This is returned, but just for ItemAPI and AnodeAPI -->
		<field name="physical" type="unchanged_string" indexed="false" stored="true" multiValued="true"/>
		<!-- This is used in the grouped work driver -->
		<field name="edition" type="unchanged_string" indexed="false" stored="true" multiValued="true"/>
		<!-- This does not seem to be used and can likely be deleted -->
		<field name="dateSpan" type="unchanged_string" indexed="false" stored="false" multiValued="true"/>
		<!-- This is returned and used as a facet. -->
		<field name="econtent_source" type="unchanged_string" indexed="true" stored="false" multiValued="true" docValues="true" omitNorms="true" omitTermFreqAndPositions="true"/>
		<!-- This is returned, used as a facet, and in the mlt handler. There are too many values for docValues to be useful. -->
		<field name="subject_facet" type="unchanged_string" indexed="true" stored="true" multiValued="true" termVectors="true"/>
		<field name="subject" type="searchable_text_minimal_stem" indexed="true" stored="false" multiValued="true"/>
		<field name="subject_proper" type="textProper" indexed="true" stored="false" multiValued="true"/>
		<field name="topic" type="searchable_text_minimal_stem" indexed="true" stored="false" multiValued="true"/>
		<field name="topic_proper" type="textProper" indexed="true" stored="false" multiValued="true"/>
		<!-- This is returned, used as a facet, and in the mlt handler. There are too many values for docValues to be useful. -->
		<field name="topic_facet" type="unchanged_string" indexed="true" stored="true" multiValued="true" termVectors="true" omitNorms="true" omitTermFreqAndPositions="true"/>
		<!-- This is returned and used as a facet. There are too many values for docValues to be useful. -->
		<field name="lc_subject" type="unchanged_string" indexed="true" stored="true" multiValued="true" omitNorms="true" omitTermFreqAndPositions="true"/>
		<!-- This is returned and used as a facet. There are too many values for docValues to be useful. -->
		<field name="bisac_subject" type="unchanged_string" indexed="true" stored="true" multiValued="true" omitNorms="true" omitTermFreqAndPositions="true"/>
		<!-- This is returned for ItemAPI and Talpa -->
		<field name="genre" type="searchable_text_minimal_stem" indexed="true" stored="true" multiValued="true"/>
		<field name="genre_proper" type="textProper" indexed="true" stored="false" multiValued="true"/>
		<!-- This is returned, used as a facet, and in the mlt handler. There are too many values for docValues to be useful. -->
		<field name="genre_facet" type="unchanged_string" indexed="true" stored="false" multiValued="true" termVectors="true" omitNorms="true" omitTermFreqAndPositions="true"/>
		<field name="geographic" type="searchable_text_minimal_stem" indexed="true" stored="false" multiValued="true"/>
		<field name="geographic_proper" type="textProper" indexed="true" stored="false" multiValued="true"/>
		<!-- This is returned, used as a facet, and in the mlt handler. -->
		<field name="geographic_facet" type="unchanged_string" indexed="true" stored="false" multiValued="true" docValues="true" termVectors="true"/>
		<!-- This is returned, used as a facet, and in the mlt handler. There are too many values for docValues to be useful. -->
		<field name="personal_name_facet" type="unchanged_string" indexed="true" stored="false" multiValued="true" termVectors="true"/>
		<!-- This is returned, used as a facet, and in the mlt handler. There are too many values for docValues to be useful. -->
