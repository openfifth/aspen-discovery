# Aspen Discovery Default Environment Configuration
# Copy this file to your deployment directory as .env and customize as needed

# =============================================================================
# ASPEN SETTINGS
# =============================================================================
LOCAL_USER_ID=1000
SITE_NAME=aspen
SUPPORTING_COMPANY=ByWater Solutions
LIBRARY=Test Library
TITLE=Aspen Discovery
URL=http://localhost:85
SOLR_HOST=solr
SOLR_PORT=8983
PHP_FPM_HOST=backend
PHP_FPM_PORT=9000
ASPEN_ADMIN_PASSWORD=secretPass123
ASPEN_HOME=./aspen

# =============================================================================
# DATABASE SETTINGS
# =============================================================================
DATABASE_HOST=db
DATABASE_PORT=3306
DATABASE_NAME=aspen
DATABASE_USER=aspenusr
DATABASE_PASSWORD=aspenpasswd
DATABASE_ROOT_USER=root
DATABASE_ROOT_PASSWORD=password
TIMEZONE=America/Argentina/Cordoba

# =============================================================================
# DOCKER IMAGES
# =============================================================================
BACKEND_IMAGE_TAG=
SOLR_IMAGE_TAG=
TUNNEL_IMAGE_TAG=
MARIADB_IMAGE=

# =============================================================================
# MYSQL TUNNEL (if needed for remote ILS connection)
# =============================================================================
TUNNEL_LOCAL_PORT=
TUNNEL_REMOTE_HOST=
TUNNEL_REMOTE_PORT=
TUNNEL_JUMP_USER=
TUNNEL_JUMP_SERVER=
