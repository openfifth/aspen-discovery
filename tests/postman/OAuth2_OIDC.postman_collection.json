    {
      "name": "Token Generation - Grant Types",
      "item": [
        {
          "name": "Password Grant - API Access Only",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var responseData = pm.response.json();",
                  "if (responseData.access_token) {",
                  "  pm.environment.set('access_token', responseData.access_token);",
                  "  pm.environment.set('token_type', responseData.token_type);",
                  "  console.log('Access token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {"key": "grant_type", "value": "password"},
                {"key": "username", "value": "{{username}}"},
                {"key": "password", "value": "{{password}}"},
                {"key": "client_id", "value": "{{client_id}}"},
                {"key": "client_secret", "value": "{{client_secret}}"},
                {"key": "scope", "value": "api:work:read api:list:read"}
              ]
            },
            "url": {
              "raw": "{{base_url}}/Authentication/OAuth2/Token",
              "host": ["{{base_url}}"],
              "path": ["Authentication", "OAuth2", "Token"]
            },
            "description": "Get access token with API scopes only (no OpenID)"
          },
          "response": []
        },
        {
          "name": "Password Grant - With OpenID & ID Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var responseData = pm.response.json();",
                  "if (responseData.access_token) {",
                  "  pm.environment.set('access_token', responseData.access_token);",
                  "  pm.environment.set('refresh_token', responseData.refresh_token);",
                  "  pm.environment.set('token_type', responseData.token_type);",
                  "}",
                  "if (responseData.id_token) {",
                  "  pm.environment.set('id_token', responseData.id_token);",
                  "  var parts = responseData.id_token.split('.');",
                  "  if (parts.length === 3) {",
                  "    var payload = JSON.parse(atob(parts[1]));",
                  "    pm.environment.set('id_token_payload', JSON.stringify(payload, null, 2));",
                  "    console.log('ID Token Claims:', payload);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {"key": "grant_type", "value": "password"},
                {"key": "username", "value": "{{username}}"},
                {"key": "password", "value": "{{password}}"},
                {"key": "client_id", "value": "{{client_id}}"},
                {"key": "client_secret", "value": "{{client_secret}}"},
                {"key": "scope", "value": "openid profile email api:work:read api:list:read"}
              ]
            },
            "url": {
              "raw": "{{base_url}}/Authentication/OAuth2/Token",
              "host": ["{{base_url}}"],
              "path": ["Authentication", "OAuth2", "Token"]
            },
            "description": "Get access token, refresh token, AND ID token with user claims"
          },
          "response": []
        },
        {
          "name": "Authorization Code Flow - Initiate",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/Authentication/OAuth2/Authorize?response_type=code&client_id={{client_id}}&redirect_uri={{redirect_uri}}&scope=openid%20profile%20email%20api:work:read&state=xyz123",
              "host": ["{{base_url}}"],
              "path": ["Authentication", "OAuth2", "Authorize"],
              "query": [
                {"key": "response_type", "value": "code"},
                {"key": "client_id", "value": "{{client_id}}"},
                {"key": "redirect_uri", "value": "{{redirect_uri}}"},
                {"key": "scope", "value": "openid profile email api:work:read"},
                {"key": "state", "value": "xyz123"}
              ]
            },
            "description": "Step 1: Get authorization code (browser redirect)"
          },
          "response": []
        },
        {
          "name": "Authorization Code Flow - Token Exchange",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {"key": "grant_type", "value": "authorization_code"},
                {"key": "code", "value": "{{auth_code}}"},
                {"key": "redirect_uri", "value": "{{redirect_uri}}"},
                {"key": "client_id", "value": "{{client_id}}"},
                {"key": "client_secret", "value": "{{client_secret}}"}
              ]
            },
            "url": {
              "raw": "{{base_url}}/Authentication/OAuth2/Token",
              "host": ["{{base_url}}"],
              "path": ["Authentication", "OAuth2", "Token"]
            },
            "description": "Step 2: Exchange authorization code for tokens"
          },
          "response": []
        },
        {
          "name": "Refresh Token Grant",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var responseData = pm.response.json();",
