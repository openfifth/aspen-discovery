    {
      "name": "Token Inspection & Testing",
      "item": [
        {
          "name": "Get and Decode ID Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Decode and inspect the ID token from Password Grant response",
                  "var responseData = pm.response.json();",
                  "if (responseData.id_token) {",
                  "  var token = responseData.id_token;",
                  "  var parts = token.split('.');",
                  "  if (parts.length === 3) {",
                  "    // Decode header",
                  "    var header = JSON.parse(atob(parts[0]));",
                  "    // Decode payload",
                  "    var payload = JSON.parse(atob(parts[1]));",
                  "    console.log('Header:', header);",
                  "    console.log('Payload:', payload);",
                  "    console.log('Signature (first 50 chars):', parts[2].substring(0, 50));",
                  "    pm.environment.set('decoded_id_token', JSON.stringify({header, payload}, null, 2));",
                  "  }",
                  "} else {",
                  "  console.log('No ID token in response');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {"key": "grant_type", "value": "password"},
                {"key": "username", "value": "{{username}}"},
                {"key": "password", "value": "{{password}}"},
                {"key": "client_id", "value": "{{client_id}}"},
                {"key": "client_secret", "value": "{{client_secret}}"},
                {"key": "scope", "value": "openid profile email"}
              ]
            },
            "url": {
              "raw": "{{base_url}}/Authentication/OAuth2/Token",
              "host": ["{{base_url}}"],
              "path": ["Authentication", "OAuth2", "Token"]
            },
            "description": "Get token and run test script to decode and inspect ID token"
          },
          "response": []
        },
        {
          "name": "Save Access Token for Reuse",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var responseData = pm.response.json();",
                  "if (responseData.access_token) {",
                  "  pm.environment.set('access_token', responseData.access_token);",
                  "  pm.environment.set('token_type', responseData.token_type);",
                  "  pm.environment.set('expires_in', responseData.expires_in);",
                  "  if (responseData.refresh_token) {",
                  "    pm.environment.set('refresh_token', responseData.refresh_token);",
                  "  }",
                  "  console.log('Tokens saved to environment');",
                  "  console.log('Token expires in:', responseData.expires_in, 'seconds');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {"key": "grant_type", "value": "password"},
                {"key": "username", "value": "{{username}}"},
                {"key": "password", "value": "{{password}}"},
                {"key": "client_id", "value": "{{client_id}}"},
                {"key": "client_secret", "value": "{{client_secret}}"},
                {"key": "scope", "value": "openid profile email api:work:read api:list:read api:user:read"}
              ]
            },
            "url": {
              "raw": "{{base_url}}/Authentication/OAuth2/Token",
              "host": ["{{base_url}}"],
              "path": ["Authentication", "OAuth2", "Token"]
            },
            "description": "Get full-scope token and automatically save it to environment for use in other requests"
          },
          "response": []
        }
      ]
